<!-- ============================================================
     MH_PAGE10 — MENU HORIZONTAL DE LA PAGE 10
     ============================================================
     <Contexte> Ce menu horizontal est associé à la Page10.
     Il permet de naviguer entre les pages principales et
     d’exécuter des actions de gestion globales de l’application. </Contexte>

     <Objectif> Fournir à l’utilisateur un accès rapide aux opérations :
       - Retour et navigation
       - Rafraîchissement de la liste
       - Intégration en stock
       - Forçage manuel
       - Accès à la page d’administration </Objectif>

     <Utilisateurs cibles> Magasiniers, responsables d’atelier
     et administrateurs d’application. </Utilisateurs>

     <Comportement> Ce menu hérite de <see cref="MH_Page_Generic"/>.
     Il ajoute les boutons spécifiques "Retour", "Intégration",
     "Forçage" et "Administration" à droite, et applique des
     règles de sécurité selon les droits d’accès utilisateur. </Comportement>
     ============================================================ -->

<generic:MH_Page_Generic x:Class="BatchStockRelease.D_Presentation.Views.Components.MenuHorizontal.MH_Page10"
                         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                         xmlns:vm="clr-namespace:BatchStockRelease.D_Presentation.ViewModels.Components.MenuHorizontal"
                         xmlns:local="clr-namespace:BatchStockRelease.D_Presentation.Utilities"
                         xmlns:generic="clr-namespace:BatchStockRelease.D_Presentation.Views.Generic"
                         mc:Ignorable="d">
    
    <Grid x:Name="MH_Grid" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="MH_Grid_C1"/>
            <ColumnDefinition x:Name="MH_Grid_C2"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="MH_Border" Grid.Column="1">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button x:Name="MH_Home" Command="{Binding HomeCommand}" Background="Transparent" BorderBrush="Transparent" Visibility="Collapsed">
                        <StackPanel Orientation="Vertical">
                            <Image x:Name="MH_Home_Icon"/>
                            <TextBlock  x:Name="MH_Home_Text" Text="{DynamicResource MH_Ti_17}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="MH_Previous"  Command="{Binding PreviousCommand}" Background="Transparent" BorderBrush="Transparent">
                        <StackPanel Orientation="Vertical">
                            <Image x:Name="MH_Previous_Icon"/>
                            <TextBlock  x:Name="MH_Previous_Text" Text="{DynamicResource MH_Ti_02}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="MH_Refresh" Command="{Binding RefreshCommand}" Background="Transparent" BorderBrush="Transparent">
                        <StackPanel Orientation="Vertical">
                            <Image x:Name="MH_Refresh_Icon"/>
                            <TextBlock  x:Name="MH_Refresh_Text" Text="{DynamicResource MH_Ti_03}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="MH_Admin"  Command="{Binding AdminCommand}" Background="Transparent" BorderBrush="Transparent" Visibility="Collapsed">
                        <StackPanel Orientation="Vertical">
                            <Image x:Name="MH_Admin_Icon"/>
                            <TextBlock  x:Name="MH_Admin_Text" Text="{DynamicResource MH_Ti_15}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel x:Name="MH_StackPanel" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="MH_Force"  Command="{Binding ForceCommand}" Background="Transparent" BorderBrush="Transparent" Visibility="Collapsed">
                        <StackPanel Orientation="Vertical">
                            <Image x:Name="MH_Force_Icon"/>
                            <TextBlock  x:Name="MH_Force_Text" Text="{DynamicResource MH_Ti_19}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="MH_Integration"  Command="{Binding IntegrationCommand}" Background="Transparent" BorderBrush="Transparent" Visibility="Collapsed">
                        <StackPanel Orientation="Vertical">
                            <Image x:Name="MH_Integration_Icon"/>
                            <TextBlock  x:Name="MH_Integration_Text" Text="{DynamicResource MH_Ti_18}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="MH_Return" Command="{Binding ReturnCommand}" Background="Transparent" BorderBrush="Transparent" Visibility="Collapsed">
                        <StackPanel Orientation="Vertical">
                            <Image x:Name="MH_Return_Icon"/>
                            <TextBlock  x:Name="MH_Return_Text" Text="{DynamicResource MH_Ti_16}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="MH_Menu" Command="{Binding MenuCommand}" Background="Transparent" BorderBrush="Transparent">
                        <StackPanel Orientation="Vertical">
                            <Image x:Name="MH_Menu_Icon"/>
                            <TextBlock  x:Name="MH_Menu_Text" Text="{DynamicResource MH_Ti_01}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</generic:MH_Page_Generic>
