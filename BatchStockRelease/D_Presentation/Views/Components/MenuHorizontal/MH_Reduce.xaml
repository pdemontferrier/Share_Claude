<UserControl x:Class="BatchStockRelease.D_Presentation.Views.Components.MenuHorizontal.MH_Reduce"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BatchStockRelease.D_Presentation.ViewModels.Components.MenuHorizontal"
>
    <Grid HorizontalAlignment="Right">
        <Border x:Name="MH_Border" HorizontalAlignment="Right">
            <Button x:Name="MH_Menu" Command="{Binding MenuCommand}" Background="Transparent" BorderBrush="Transparent">
                <StackPanel Orientation="Vertical">
                    <Image x:Name="MH_Menu_Icon"/>
                    <TextBlock  x:Name="MH_Menu_Text" Text="{DynamicResource MH_Ti_01}"/>
                </StackPanel>
            </Button>
        </Border>
    </Grid>
</UserControl>