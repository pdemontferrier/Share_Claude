<!-- ============================================================
     PAGE 00 — CONNEXION UTILISATEUR (BatchStockRelease)
     ============================================================
     <Contexte> Page d’accueil de l’application, permet à
     l’utilisateur de s’authentifier avant d’accéder aux autres pages. </Contexte>

     <Objectif> Vérifier les identifiants de connexion
     (login/mot de passe) et initialiser la session utilisateur. </Objectif>

     <Utilisateurs cibles> Tous les utilisateurs de l’ERP
     (magasiniers, chefs d’atelier, opérateurs, administrateurs). </Utilisateurs>

     <Composants principaux>
       - Zone d’identification (Login / Password)
       - Bouton de connexion
       - Gestion du focus automatique
     ============================================================ -->
    
<generic:Page_Generic x:Class="BatchStockRelease.D_Presentation.Views.Pages.Page00"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                      xmlns:generic="clr-namespace:BatchStockRelease.D_Presentation.Views.Generic"
                      xmlns:utils="clr-namespace:BatchStockRelease.D_Presentation.Utilities"
                      mc:Ignorable="d" 
                      Title="Page00">

    <Grid x:Name="PageGrid">

        <!-- Conteneur principal pour centrer -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Zone encadrée -->
            <Border x:Name="IdentificationBorder" Grid.Row="1" Grid.Column="1" CornerRadius="10" Padding="20">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="55"/>
                        <RowDefinition Height="55"/>
                        <RowDefinition Height="55"/>
                    </Grid.RowDefinitions>

                    <!-- Première ligne -->
                    <TextBlock x:Name="IdentificationData" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                               VerticalAlignment="Center" Text="{DynamicResource P00_00}"/>

                    <!-- Deuxième ligne -->
                    <TextBlock x:Name="LoginTitle" Grid.Row="1" Grid.Column="0" 
                               VerticalAlignment="Center" Text="{DynamicResource P00_01}"/>
                    <Border x:Name="LoginBorder" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center">
                        <TextBox x:Name="LoginInput"
                                 Text="{Binding Login, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                    </Border>

                    <!-- Troisième ligne -->
                    <TextBlock x:Name="PasswordTitle" Grid.Row="2" Grid.Column="0"
                               VerticalAlignment="Center" Text="{DynamicResource P00_02}"/>
                    <Border x:Name="PasswordBorder" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center">
                        <PasswordBox x:Name="PasswordInput"
                                     utils:UT_PasswordBoxHelper.BindPassword="True"
                                     utils:UT_PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay}"/>
                    </Border>

                    <!-- Troisième colonne : bouton -->
                    <Button x:Name="LoginButton" Grid.Row="1" Grid.Column="2" Grid.RowSpan="2" VerticalAlignment="Center" 
                            Command="{Binding LoginCommand}">
                        <TextBlock x:Name="LoginButtonText" Text="{DynamicResource P00_03}"/>
                    </Button>

                </Grid>
            </Border>
        </Grid>

    </Grid>
</generic:Page_Generic>
