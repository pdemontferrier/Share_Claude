<!-- ============================================================
     PAGE 30 - SORTIE DE STOCK DES BARRES (BatchStockRelease)
    =================================================================
     Contexte : Permet aux magasiniers de visualiser les sorties de barres
                pour un lot de fabrication. Les barres déjà sortie sont
                colorisées en vert.
     Contenu :
       - Onglet 1 : BarDrop   → Chutes attribuées au lot.
       - Onglet 2 : BarNew    → Barres neuves calculées à sortir.
       - Onglet 3 : OutOfStock → Barres en rupture à traiter manuellement.
     ============================================================ -->
<generic:Page_Generic x:Class="BatchStockRelease.D_Presentation.Views.Pages.Page30"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                      xmlns:generic="clr-namespace:BatchStockRelease.D_Presentation.Views.Generic"
                      mc:Ignorable="d" 
                      Title="Page30">

    <Grid x:Name="PageGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Première ligne -->
        <TextBlock x:Name="PageTitleMain" Grid.Row="0" Grid.Column="0" Text="{Binding BatchDesignation}"/>
       
        <!-- Cadre des onglets -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" Grid.Column="0" Height="400">

            <!-- === ONGLET 1 : CHUTES ATTRIBUÉES (BarDrop) === -->
            <TabItem x:Name="BarDropTabItem" Header="{DynamicResource P30_01}">
                <StackPanel>
                    <!-- Deuxième ligne -->
                    <Border x:Name="BarDropBorder" Grid.Row="0" Grid.Column="0">
                        <TextBlock x:Name="BarDropHeader" Text="{DynamicResource P30_00}"/>
                    </Border>

                    <!-- Troisième ligne -->
                    <!-- Colonne 1 -->
                    <ScrollViewer x:Name="BarDropScrollViewer" Grid.Row="1" Grid.Column="0">
                        <ListView x:Name="BarDropListView" ItemsSource="{Binding BarDropList}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel.Resources>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ApproSortieFaite}" Value="True">
                                                        <Setter Property="Foreground" Value="#59C64A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Resources>
                                        
                                        <TextBlock Text="{Binding Reference}" Width="150"/>
                                        <TextBlock Text="{Binding Designation}" Width="300"/>
                                        <TextBlock Text="{Binding Couleur}" Width="100"/>
                                        <TextBlock Text="{Binding ApproCodeBarre}" Width="200"/>
                                        <TextBlock Text="{Binding LongueurBarre, StringFormat={}{0:N0}}" Width="100"/>
                                        <TextBlock Text="{Binding ApproEmplacementDesignation}" Width="100"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </ScrollViewer>
                </StackPanel>
            </TabItem>


            <!-- === ONGLET 2 : BARRES NEUVES ATTRIBUÉES (BarNew) === -->
            <TabItem x:Name="BarNewTabItem" Header="{DynamicResource P30_03}">
                <StackPanel>
                    <!-- Deuxième ligne -->
                    <Border x:Name="BarNewBorder" Grid.Row="0" Grid.Column="0">
                        <TextBlock x:Name="BarNewHeader" Text="{DynamicResource P30_02}"/>
                    </Border>

                    <!-- Troisième ligne -->
                    <!-- Colonne 1 -->
                    <ScrollViewer x:Name="BarNewScrollViewer" Grid.Row="1" Grid.Column="0">
                        <ListView x:Name="BarNewListView" ItemsSource="{Binding BarNewList}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel.Resources>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ApproSortieFaite}" Value="True">
                                                        <Setter Property="Foreground" Value="#59C64A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Resources>
                                        
                                        <TextBlock Text="{Binding Reference}" Width="150"/>
                                        <TextBlock Text="{Binding Designation}" Width="300"/>
                                        <TextBlock Text="{Binding Couleur}" Width="100"/>
                                        <TextBlock Text="{Binding LongueurBarre, StringFormat={}{0:N0}}" Width="80"/>
                                        <TextBlock Text="{Binding QuantiteASortir}" Width="80"/>
                                        <TextBlock Text="{Binding ApproAdresseDesignation}" Width="100"/>
                                        <TextBlock Text="{Binding ApproConteneur}" Width="80"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </ScrollViewer>
                </StackPanel>
            </TabItem>

            <!-- === ONGLET 3 : RUPTURES DE STOCK (OutOfStock) === -->
            <TabItem x:Name="OutOfStockTabItem" Header="{DynamicResource P30_05}">
                <StackPanel>
                    <!-- Deuxième ligne -->
                    <Border x:Name="OutOfStockBorder" Grid.Row="0" Grid.Column="0">
                        <TextBlock x:Name="OutOfStockHeader" Text="{DynamicResource P30_04}"/>
                    </Border>

                    <!-- Troisième ligne -->
                    <!-- Colonne 1 -->
                    <ScrollViewer x:Name="OutOfStockScrollViewer" Grid.Row="1" Grid.Column="0">
                        <ListView x:Name="OutOfStockListView" ItemsSource="{Binding OutOfStockList}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel.Resources>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding ApproRupture}" Value="True"/>
                                                            <Condition Binding="{Binding ApproSortieForce}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Foreground" Value="#FF3E3E"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Resources>

                                        <TextBlock Text="{Binding Reference}" Width="150"/>
                                        <TextBlock Text="{Binding Designation}" Width="300"/>
                                        <TextBlock Text="{Binding Couleur}" Width="100"/>
                                        <TextBlock Text="{Binding LongueurBarre, StringFormat={}{0:N0}}" Width="100"/>
                                        <TextBlock Text="{Binding QuantiteASortir}" Width="100"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </ScrollViewer>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</generic:Page_Generic> 