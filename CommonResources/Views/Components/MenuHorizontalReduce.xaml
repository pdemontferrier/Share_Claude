<UserControl x:Class="CommonResources.Views.Components.MenuHorizontalReduce"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
    <Grid HorizontalAlignment="Right">
        <Border x:Name="MHR" HorizontalAlignment="Right">
            <Button x:Name="MHR_Menu" Background="Transparent" BorderBrush="Transparent">
                <StackPanel Orientation="Vertical">
                    <Image x:Name="MHR_Menu_Icon"/>
                    <TextBlock  x:Name="MHR_Menu_Text"/>
                </StackPanel>
            </Button>
        </Border>
    </Grid>
</UserControl>
