<Window x:Class="CommonResources.Views.Components.DialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CommonResources.Views.Components"
        Title="Fenêtre d'information"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize">

    <Grid x:Name="MainGrid" Background="White" >
        <Border x:Name="Background_1"/>
        <Border x:Name="TitleBorder">
            <Grid x:Name="TitleGrid">
                <Image x:Name="LogoImage"/>
                <TextBlock  x:Name="TitleContent"/>
            </Grid>
        </Border>
        <TextBlock  x:Name="MainContent"
                    TextWrapping="Wrap"
                    TextAlignment="Center"
                    VerticalAlignment="Center"
                    Margin= "30,0,30,0"/>
    </Grid>
</Window>

