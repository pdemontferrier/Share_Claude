<!--
=====================================================================================
Composant : Page01.xaml
=====================================================================================
Description :
    Vue WPF de la page Utilisateur Page01 de l'application DG244Cutting. Présente,
    dans un TabControl à deux onglets, les informations d'identification de
    l'utilisateur applicatif et du poste courant (Onglet 1, "Utilisateur"), et la
    liste des droits d'accès granulaires de l'utilisateur courant aux pages de
    l'application courante (Onglet 2, "Droits d'accès").

Contexte :
    Page accessible à tout utilisateur connecté, en lecture seule. La page n'expose
    aucune commande utilisateur ; la sortie s'effectue exclusivement via les boutons
    transverses du menu horizontal (Home, Previous) portés par le couple
    VM_MH_Generic / MH_Generic.

Structure visuelle :
    - Élément racine generic:Page_Generic, héritant du socle Page_Generic (cycle de
      vie WPF, filet de sécurité ultime au bord des handlers, résolution
      d'IS_ControlStyler et d'ISE_Window via Service Locator).
    - Grid central nommé PageGrid, conteneur unique de la page, stylé au Loaded par
      IS_ControlStyler.StylePage(PageGrid). Accueille comme unique enfant direct le
      TabControl MainTabControl.
    - TabControl MainTabControl à deux TabItems :
        · UserDetailsTabItem (Header bindé sur Label_P01_10 via le TextBlock
          UserDetailsTabHeader) — contient un Border UserDetailsBorder englobant
          un Grid UserDetailsGrid à 2 colonnes (300, *) et 5 lignes (MinHeight=40).
          Col 0 : 5 TextBlocks titres (IDTitle, UserFullNameTitle, DeviceUserTitle,
          DeviceIdTitle, DeviceIPTitle) bindés sur Label_P01_01..05. Col 1 :
          5 TextBlocks data (IDData, UserFullNameData, DeviceUserData, DeviceIdData,
          DeviceIPData) bindés sur UserId, UserFullName, DeviceUser, DeviceId,
          DeviceIP.
        · UserAccessTabItem (Header bindé sur Label_P01_11 via le TextBlock
          UserAccessTabHeader) — contient un Grid UserAccessGrid à 1 colonne et
          2 lignes englobant un StackPanel vertical avec deux blocs :
            (a) Border UserAccessHeaderBorder contenant un StackPanel horizontal
                avec les 11 TextBlocks UserAccessHeader01..11 bindés sur
                Label_P01_13..23 (largeurs 200 / 10×100) ;
            (b) ScrollViewer UserAccessScrollViewer contenant la ListView
                UserAccessListView dont ItemsSource est bindée sur
                PagesUserRights. Le DataTemplate porte un StackPanel horizontal
                avec un TextBlock bindé sur PageCode (largeur 200) et 10 CheckBox
                en lecture seule (IsEnabled="False", largeur 100) bindées sur
                CanAccess, CanRead, CanUpdate, CanCreate, CanDelete, CanControl,
                CanValidate, CanSupervise, CanMonitor, CanAdmin.

Bindings principaux :
    - 18 bindings de libellés multilingues : Label_P01_01..05 (titres Onglet 1),
      Label_P01_10/11 (Headers TabItem), Label_P01_13..23 (en-têtes Onglet 2).
    - 5 bindings de données d'identification : UserId, UserFullName, DeviceUser,
      DeviceId, DeviceIP.
    - 1 binding de collection : PagesUserRights (ItemsSource de la ListView).
    - 10 bindings dans le DataTemplate de la ListView : PageCode, CanAccess,
      CanRead, CanUpdate, CanCreate, CanDelete, CanControl, CanValidate,
      CanSupervise, CanMonitor, CanAdmin.

Remarques techniques :
    - Aucune chaîne UI en dur (I-4.11.1 du 0231) : tout texte affiché est issu
      d'un binding sur une propriété observable du ViewModel.
    - Aucune DynamicResource ni StaticResource pour les textes UI (I-4.11.10 du
      0231) : le chargement des libellés est porté exclusivement par le
      ViewModel via la mécanique multilingue héritée de VM_Generic.
    - Les noms d'éléments (x:Name) sont strictement ceux attendus par les
      signatures de IS_ControlStyler (StylePage, StyleTabControl, StyleTabItemTitle,
      StyleTextBlockHeader, StyleBorder, StyleTextBlockTitle, StyleTextBlockData,
      StyleBorderHeader, StyleScrollViewer variadique à 11 en-têtes, StyleListView)
      et par le calcul dimensionnel d'OnResized (MainTabControl,
      UserAccessScrollViewer) — toute modification casserait la stylisation ou le
      redimensionnement appliqués au Loaded et au SizeChanged par le code-behind.
    - La stylisation visuelle (couleurs, polices, dimensions, mise en forme) est
      intégralement appliquée au Loaded par le code-behind via IS_ControlStyler dans
      l'override ApplyLayout ; aucun style WPF n'est défini ici. L'ajustement
      dynamique de la hauteur du TabControl et du ScrollViewer est appliqué au
      Loaded puis à chaque SizeChanged par l'override OnResized.
    - Aucun chargement de libellé depuis ce fichier ni depuis son code-behind
      (I-4.11.10 du 0231) ; les libellés sont chargés exclusivement par le
      ViewModel via la mécanique multilingue héritée.
    - Le DataTemplate de la ListView n'est pas stylisé par IS_ControlStyler : le
      contrat ne porte aucune méthode dédiée à la stylisation des éléments
      d'ItemTemplate (parité legacy Page90).
=====================================================================================
-->
<generic:Page_Generic x:Class="DG244Cutting.D_Presentation.Views.Pages.Page01"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                      xmlns:local="clr-namespace:DG244Cutting.D_Presentation.Views.Pages"
                      xmlns:generic="clr-namespace:DG244Cutting.D_Presentation.Views.Generic"
                      Title="Page01"
                      mc:Ignorable="d">

    <Grid x:Name="PageGrid">

        <TabControl x:Name="MainTabControl">

            <!-- ============================================================ -->
            <!-- Onglet 1 — Informations d'identification utilisateur / poste -->
            <!-- ============================================================ -->
            <TabItem x:Name="UserDetailsTabItem">
                <TabItem.Header>
                    <TextBlock x:Name="UserDetailsTabHeader" Text="{Binding Label_P01_10}"/>
                </TabItem.Header>

                <Border x:Name="UserDetailsBorder" Padding="5,20,5,20">
                    <Grid x:Name="UserDetailsGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition MinHeight="40"/>
                            <RowDefinition MinHeight="40"/>
                            <RowDefinition MinHeight="40"/>
                            <RowDefinition MinHeight="40"/>
                            <RowDefinition MinHeight="40"/>
                        </Grid.RowDefinitions>

                        <!-- Colonne 0 — Titres -->
                        <TextBlock x:Name="IDTitle"             Grid.Row="0" Grid.Column="0" Text="{Binding Label_P01_01}"/>
                        <TextBlock x:Name="UserFullNameTitle"   Grid.Row="1" Grid.Column="0" Text="{Binding Label_P01_02}"/>
                        <TextBlock x:Name="DeviceUserTitle"     Grid.Row="2" Grid.Column="0" Text="{Binding Label_P01_03}"/>
                        <TextBlock x:Name="DeviceIdTitle"       Grid.Row="3" Grid.Column="0" Text="{Binding Label_P01_04}"/>
                        <TextBlock x:Name="DeviceIPTitle"       Grid.Row="4" Grid.Column="0" Text="{Binding Label_P01_05}"/>

                        <!-- Colonne 1 — Données -->
                        <TextBlock x:Name="IDData"              Grid.Row="0" Grid.Column="1" Text="{Binding UserId}"/>
                        <TextBlock x:Name="UserFullNameData"    Grid.Row="1" Grid.Column="1" Text="{Binding UserFullName}"/>
                        <TextBlock x:Name="DeviceUserData"      Grid.Row="2" Grid.Column="1" Text="{Binding DeviceUser}"/>
                        <TextBlock x:Name="DeviceIdData"        Grid.Row="3" Grid.Column="1" Text="{Binding DeviceId}"/>
                        <TextBlock x:Name="DeviceIPData"        Grid.Row="4" Grid.Column="1" Text="{Binding DeviceIP}"/>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ============================================================ -->
            <!-- Onglet 2 — Droits d'accès granulaires aux pages              -->
            <!-- ============================================================ -->
            <TabItem x:Name="UserAccessTabItem">
                <TabItem.Header>
                    <TextBlock x:Name="UserAccessTabHeader" Text="{Binding Label_P01_11}"/>
                </TabItem.Header>

                <Grid x:Name="UserAccessGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition MinHeight="40"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <!-- En-têtes de colonnes -->
                        <Border x:Name="UserAccessHeaderBorder">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="UserAccessHeader01" Text="{Binding Label_P01_13}" Width="200"/>
                                <TextBlock x:Name="UserAccessHeader02" Text="{Binding Label_P01_14}" Width="100"/>
                                <TextBlock x:Name="UserAccessHeader03" Text="{Binding Label_P01_15}" Width="100"/>
                                <TextBlock x:Name="UserAccessHeader04" Text="{Binding Label_P01_16}" Width="100"/>
                                <TextBlock x:Name="UserAccessHeader05" Text="{Binding Label_P01_17}" Width="100"/>
                                <TextBlock x:Name="UserAccessHeader06" Text="{Binding Label_P01_18}" Width="100"/>
                                <TextBlock x:Name="UserAccessHeader07" Text="{Binding Label_P01_19}" Width="100"/>
                                <TextBlock x:Name="UserAccessHeader08" Text="{Binding Label_P01_20}" Width="100"/>
                                <TextBlock x:Name="UserAccessHeader09" Text="{Binding Label_P01_21}" Width="100"/>
                                <TextBlock x:Name="UserAccessHeader10" Text="{Binding Label_P01_22}" Width="100"/>
                                <TextBlock x:Name="UserAccessHeader11" Text="{Binding Label_P01_23}" Width="100"/>
                            </StackPanel>
                        </Border>

                        <!-- Liste des droits d'accès -->
                        <ScrollViewer x:Name="UserAccessScrollViewer">
                            <ListView x:Name="UserAccessListView" ItemsSource="{Binding PagesUserRights}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding PageCode}"                   Width="200"/>
                                            <CheckBox  IsChecked="{Binding CanAccess}"    IsEnabled="False" Width="100"/>
                                            <CheckBox  IsChecked="{Binding CanRead}"      IsEnabled="False" Width="100"/>
                                            <CheckBox  IsChecked="{Binding CanUpdate}"    IsEnabled="False" Width="100"/>
                                            <CheckBox  IsChecked="{Binding CanCreate}"    IsEnabled="False" Width="100"/>
                                            <CheckBox  IsChecked="{Binding CanDelete}"    IsEnabled="False" Width="100"/>
                                            <CheckBox  IsChecked="{Binding CanControl}"   IsEnabled="False" Width="100"/>
                                            <CheckBox  IsChecked="{Binding CanValidate}"  IsEnabled="False" Width="100"/>
                                            <CheckBox  IsChecked="{Binding CanSupervise}" IsEnabled="False" Width="100"/>
                                            <CheckBox  IsChecked="{Binding CanMonitor}"   IsEnabled="False" Width="100"/>
                                            <CheckBox  IsChecked="{Binding CanAdmin}"     IsEnabled="False" Width="100"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </ScrollViewer>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>

    </Grid>

</generic:Page_Generic>