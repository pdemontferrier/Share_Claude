<!--
=====================================================================================
Composant : Page04.xaml
=====================================================================================
Description :
    Vue WPF de la page d'administration des comptes applicatifs Page04 de
    l'application DG244Cutting. Présente, dans un TabControl à deux onglets, la liste
    des comptes administrables (Onglet 1, « Liste des utilisateurs ») et la fiche
    d'édition d'un compte à trois modes — Consultation, Modification, Création
    (Onglet 2, « Détails utilisateur »).

Contexte :
    Page d'administration. Les commandes de création, de modification et de
    persistance ne sont pas portées par la page : elles sont pilotées par le menu
    horizontal dédié via le contrat partagé IV_Page04 réalisé par VM_Page04. La page
    n'expose donc aucun bouton d'action ; elle expose la liste, la fiche éditable et
    la garde de changement d'onglet.

Structure visuelle :
    - Élément racine generic:Page_Generic (cycle de vie WPF, filet de sécurité ultime,
      résolution d'IS_ControlStyler et d'ISE_Window via Service Locator).
    - Ressource locale UT_InverseBooleanConverter (x:Key="InverseBooleanConverter"),
      unique StaticResource admise, servant à dériver IsReadOnly des prédicats de
      verrou exposés par le ViewModel.
    - Grid central PageGrid, conteneur unique, accueillant le TabControl MainTabControl.
    - TabControl MainTabControl : SelectedIndex lié en TwoWay à ActiveTabIndex ; garde
      de sortie d'onglet câblée via UT_BindingTabChangeGuard.Guard = LeaveTabGuard.
        · Onglet 1 UserListTabItem (Header bindé sur Label_P04_01) — Grid UserListGrid
          contenant un StackPanel : Border UserListHeaderBorder (StackPanel horizontal
          des 5 en-têtes UserListHeader01..05 bindés sur Label_P04_05..09), puis
          ScrollViewer UserListScrollViewer englobant la ListView UserListView
          (ItemsSource = UserApps, SelectedItem lié en TwoWay à SelectedRecord). Le
          DataTemplate porte un StackPanel horizontal : 4 TextBlock (LastName,
          FirstName, Login, WindowsLogin) et un CheckBox IsActive en lecture seule.
        · Onglet 2 UserDetailsTabItem (Header bindé sur Label_P04_02 ; IsEnabled lié à
          IsTab2Available) — Border UserDetailsBorder englobant un Grid UserDetailsGrid
          à 2 colonnes (200, *) et 7 lignes. Colonne 0 : 7 TextBlock titres
          (Label_P04_11..17). Colonne 1 : 4 TextBox (LastName, FirstName, Login,
          WindowsLogin), 2 PasswordBox (Password, PasswordConfirmation) et 1 CheckBox
          (IsActive), tous en liaison TwoWay.

Verrouillage de la fiche :
    - LastNameInput / FirstNameInput : IsReadOnly = !IsFormEditable (éditables en
      Création et Modification).
    - LoginInput / WindowsLoginInput : IsReadOnly = !IsLoginEditable (éditables en
      Création uniquement, immuables en Modification).
    - PasswordInput / PasswordConfirmationInput / IsActiveInput : IsEnabled =
      IsFormEditable.

Remarques techniques :
    - Aucune chaîne UI en dur (I-4.11.1 du 0231) : tout texte affiché est issu d'un
      binding sur une propriété observable du ViewModel.
    - Aucune DynamicResource ni StaticResource pour les textes UI (I-4.11.10 du 0231) ;
      la seule StaticResource admise est le converter de verrou.
    - Les x:Name sont ceux attendus par les signatures d'IS_ControlStyler consommées
      dans l'override ApplyLayout du code-behind ; toute modification casserait la
      stylisation appliquée au Loaded.
    - La stylisation visuelle (couleurs, polices, dimensions) est appliquée au Loaded
      par le code-behind via IS_ControlStyler dans ApplyLayout ; aucun style WPF n'est
      défini ici.
    - Le DataTemplate de la ListView n'est pas stylisé par IS_ControlStyler : le contrat
      ne porte aucune méthode dédiée aux éléments d'ItemTemplate (parité Page01).
=====================================================================================
-->
<generic:Page_Generic x:Class="DG244Cutting.D_Presentation.Views.Pages.Page04"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:local="clr-namespace:DG244Cutting.D_Presentation.Views.Pages"
                      xmlns:generic="clr-namespace:DG244Cutting.D_Presentation.Views.Generic"
                      xmlns:bindings="clr-namespace:DG244Cutting.D_Presentation.Utilities.Bindings"
                      xmlns:converters="clr-namespace:DG244Cutting.D_Presentation.Utilities.Converters"
                      Title="Page04"
                      mc:Ignorable="d">

    <generic:Page_Generic.Resources>
        <converters:UT_InverseBooleanConverter x:Key="InverseBooleanConverter" />
    </generic:Page_Generic.Resources>

    <Grid x:Name="PageGrid">

        <TabControl x:Name="MainTabControl"
                    SelectedIndex="{Binding ActiveTabIndex, Mode=TwoWay}"
                    bindings:UT_BindingTabChangeGuard.Guard="{Binding LeaveTabGuard}">

            <!-- ============================================================ -->
            <!-- Onglet 1 — Liste des comptes administrables                  -->
            <!-- ============================================================ -->
            <TabItem x:Name="UserListTabItem">
                <TabItem.Header>
                    <TextBlock x:Name="UserListTabHeader" Text="{Binding Label_P04_01}"/>
                </TabItem.Header>

                <Grid x:Name="UserListGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition MinHeight="40"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <!-- En-têtes de colonnes -->
                        <Border x:Name="UserListHeaderBorder">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="UserListHeader01" Text="{Binding Label_P04_05}" Width="200"/>
                                <TextBlock x:Name="UserListHeader02" Text="{Binding Label_P04_06}" Width="200"/>
                                <TextBlock x:Name="UserListHeader03" Text="{Binding Label_P04_07}" Width="150"/>
                                <TextBlock x:Name="UserListHeader04" Text="{Binding Label_P04_08}" Width="180"/>
                                <TextBlock x:Name="UserListHeader05" Text="{Binding Label_P04_09}" Width="60"/>
                            </StackPanel>
                        </Border>

                        <!-- Liste des comptes -->
                        <ScrollViewer x:Name="UserListScrollViewer">
                            <ListView x:Name="UserListView"
                                      ItemsSource="{Binding UserApps}"
                                      SelectedItem="{Binding SelectedRecord, Mode=TwoWay}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding LastName}"      Width="200"/>
                                            <TextBlock Text="{Binding FirstName}"     Width="200"/>
                                            <TextBlock Text="{Binding Login}"         Width="150"/>
                                            <TextBlock Text="{Binding WindowsLogin}"  Width="180"/>
                                            <CheckBox  IsChecked="{Binding IsActive}" IsEnabled="False" Width="60"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </ScrollViewer>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ============================================================ -->
            <!-- Onglet 2 — Fiche d'édition d'un compte                       -->
            <!-- ============================================================ -->
            <TabItem x:Name="UserDetailsTabItem" IsEnabled="{Binding IsTab2Available}">
                <TabItem.Header>
                    <TextBlock x:Name="UserDetailsTabHeader" Text="{Binding Label_P04_02}"/>
                </TabItem.Header>

                <Border x:Name="UserDetailsBorder" Padding="5,20,5,20">
                    <Grid x:Name="UserDetailsGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition MinHeight="40"/>
                            <RowDefinition MinHeight="40"/>
                            <RowDefinition MinHeight="40"/>
                            <RowDefinition MinHeight="40"/>
                            <RowDefinition MinHeight="40"/>
                            <RowDefinition MinHeight="40"/>
                            <RowDefinition MinHeight="40"/>
                        </Grid.RowDefinitions>

                        <!-- Nom -->
                        <TextBlock x:Name="LastNameTitle" Grid.Row="0" Grid.Column="0"
                                   VerticalAlignment="Center" Text="{Binding Label_P04_11}"/>
                        <TextBox x:Name="LastNameInput" Grid.Row="0" Grid.Column="1"
                                 VerticalAlignment="Center"
                                 Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                 IsReadOnly="{Binding IsFormEditable, Converter={StaticResource InverseBooleanConverter}}"/>

                        <!-- Prénom -->
                        <TextBlock x:Name="FirstNameTitle" Grid.Row="1" Grid.Column="0"
                                   VerticalAlignment="Center" Text="{Binding Label_P04_12}"/>
                        <TextBox x:Name="FirstNameInput" Grid.Row="1" Grid.Column="1"
                                 VerticalAlignment="Center"
                                 Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                 IsReadOnly="{Binding IsFormEditable, Converter={StaticResource InverseBooleanConverter}}"/>

                        <!-- Identifiant -->
                        <TextBlock x:Name="LoginTitle" Grid.Row="2" Grid.Column="0"
                                   VerticalAlignment="Center" Text="{Binding Label_P04_13}"/>
                        <TextBox x:Name="LoginInput" Grid.Row="2" Grid.Column="1"
                                 VerticalAlignment="Center"
                                 Text="{Binding Login, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                 IsReadOnly="{Binding IsLoginEditable, Converter={StaticResource InverseBooleanConverter}}"/>

                        <!-- Identifiant Windows -->
                        <TextBlock x:Name="WindowsLoginTitle" Grid.Row="3" Grid.Column="0"
                                   VerticalAlignment="Center" Text="{Binding Label_P04_14}"/>
                        <TextBox x:Name="WindowsLoginInput" Grid.Row="3" Grid.Column="1"
                                 VerticalAlignment="Center"
                                 Text="{Binding WindowsLogin, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                 IsReadOnly="{Binding IsLoginEditable, Converter={StaticResource InverseBooleanConverter}}"/>

                        <!-- Mot de passe -->
                        <TextBlock x:Name="PasswordTitle" Grid.Row="4" Grid.Column="0"
                                   VerticalAlignment="Center" Text="{Binding Label_P04_15}"/>
                        <PasswordBox x:Name="PasswordInput" Grid.Row="4" Grid.Column="1"
                                     VerticalAlignment="Center"
                                     IsEnabled="{Binding IsFormEditable}"
                                     bindings:UT_BindingPasswordBox.EnableBinding="True"
                                     bindings:UT_BindingPasswordBox.Password="{Binding Password, Mode=TwoWay}"/>

                        <!-- Confirmation -->
                        <TextBlock x:Name="PasswordConfirmationTitle" Grid.Row="5" Grid.Column="0"
                                   VerticalAlignment="Center" Text="{Binding Label_P04_16}"/>
                        <PasswordBox x:Name="PasswordConfirmationInput" Grid.Row="5" Grid.Column="1"
                                     VerticalAlignment="Center"
                                     IsEnabled="{Binding IsFormEditable}"
                                     bindings:UT_BindingPasswordBox.EnableBinding="True"
                                     bindings:UT_BindingPasswordBox.Password="{Binding PasswordConfirmation, Mode=TwoWay}"/>

                        <!-- Actif -->
                        <TextBlock x:Name="IsActiveTitle" Grid.Row="6" Grid.Column="0"
                                   VerticalAlignment="Center" Text="{Binding Label_P04_17}"/>
                        <CheckBox x:Name="IsActiveInput" Grid.Row="6" Grid.Column="1"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding IsActive, Mode=TwoWay}"
                                  IsEnabled="{Binding IsFormEditable}"/>
                    </Grid>
                </Border>
            </TabItem>

        </TabControl>

    </Grid>

</generic:Page_Generic>
