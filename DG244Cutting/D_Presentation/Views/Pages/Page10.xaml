<!--
=====================================================================================
Composant : Page10.xaml
=====================================================================================
Description :
    Vue WPF du tableau de bord des séries de production Page10 de l'application
    DG244Cutting. Page d'accueil affichée après authentification, point d'entrée du
    flux de traitement d'une série. Présente en cinq colonnes les séries de
    production admissibles réparties selon leur statut de classement : à réaliser,
    en retard, en cours, réalisées, à venir.

Contexte :
    Transposition à cinq colonnes de la Page10 du projet legacy BatchStockRelease
    (qui en comptait deux). La sélection d'une série par clic simple sur une ligne
    est portée par la commande SelectSeriesCommand de VM_Page10 : elle mémorise la
    série dans l'état métier partagé puis navigue vers la première page adéquate du
    flux de traitement. La page n'expose aucun bouton d'action.

Structure visuelle :
    - Élément racine generic:Page_Generic (cycle de vie WPF, filet de sécurité ultime,
      résolution d'IS_ControlStyler et d'ISE_Window via Service Locator).
    - Ressources : trois convertisseurs à sens unique déclarés en StaticResource
      (UT_ProductionEndDayToBrush, UT_IsLateToFontWeight, UT_TruncateString).
    - Grid central PageGrid à cinq colonnes de largeur égale et trois lignes :
        · Row 0 : TextBlock PageTitleMain, titre unique de la page en span sur les
          cinq colonnes (Grid.ColumnSpan="5"), bindé sur PageName (clé P10_00).
        · Row 1 : cinq Border d'en-tête (un par colonne), chacun contenant un
          TextBlock d'en-tête bindé sur Label_P10_01..05 (correspondance directe
          avec les statuts ToDo..Upcoming).
        · Row 2 : cinq ScrollViewer > ListView (un par colonne), ItemsSource bindé
          sur SeriesToDo..SeriesUpcoming.

DataTemplate de ligne :
    - IdSerialNumber : numéro de série.
    - Description : tronquée à 15 caractères (ellipse comprise) via UT_TruncateString
      (ConverterParameter=15), source non altérée.
    - Fond de ligne : via UT_ProductionEndDayToBrush lié à ProductionEndDay.
    - Graisse de police : via UT_IsLateToFontWeight lié à IsLate.
    - Câblage du clic : InputBinding (MouseBinding Gesture="LeftClick") porté par le
      DataTemplate de ligne, attaché au StackPanel racine de la ligne via
      StackPanel.InputBindings, déclenchant SelectSeriesCommand avec le
      DTO_ProductionSeriesItem de la ligne en CommandParameter (clic simple, DTO de
      la ligne). La commande est résolue sur le DataContext de la page via un
      binding relatif à l'ancêtre generic:Page_Generic.

Remarques techniques :
    - Aucune chaîne UI en dur (I-4.11.1 du 0231) : tout texte affiché est issu d'un
      binding sur une propriété observable du ViewModel.
    - Aucun DynamicResource ni StaticResource pour les textes UI (I-4.11.10 du 0231) ;
      les titres et en-têtes sont bindés sur les propriétés observables du ViewModel.
      Les seules StaticResource admises sont les trois convertisseurs.
    - Les x:Name sont ceux attendus par les signatures d'IS_ControlStyler consommées
      dans l'override ApplyLayout du code-behind ; toute modification casserait la
      stylisation appliquée au Loaded.
    - La stylisation visuelle (couleurs, polices, dimensions) est appliquée au Loaded
      par le code-behind via IS_ControlStyler dans ApplyLayout ; aucun style WPF n'est
      défini ici, en particulier aucun ItemContainerStyle : la stylisation d'item est
      intégralement portée par le style implicite typeof(ListViewItem) déposé dans
      ListView.Resources par StyleListView (parité étalon Page04, qui ne pose aucun
      ItemContainerStyle). Le câblage du clic est porté par le DataTemplate de ligne
      (MouseBinding sur le StackPanel racine), non par un ItemContainerStyle.
    - Le DataTemplate de ligne n'est pas stylisé par IS_ControlStyler : le contrat ne
      porte aucune méthode dédiée aux éléments d'ItemTemplate (parité Page04).
=====================================================================================
-->
<generic:Page_Generic x:Class="DG244Cutting.D_Presentation.Views.Pages.Page10"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:generic="clr-namespace:DG244Cutting.D_Presentation.Views.Generic"
                      xmlns:converters="clr-namespace:DG244Cutting.D_Presentation.Utilities.Converters"
                      Title="Page10"
                      mc:Ignorable="d">

    <generic:Page_Generic.Resources>
        <converters:UT_ProductionEndDayToBrush x:Key="ProductionEndDayToBrush" />
        <converters:UT_IsLateToFontWeight x:Key="IsLateToFontWeight" />
        <converters:UT_TruncateString x:Key="TruncateString" />
    </generic:Page_Generic.Resources>

    <Grid x:Name="PageGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="43" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Row 0 — Titre unique de la page, en span sur les cinq colonnes -->
        <TextBlock x:Name="PageTitleMain"
                   Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5"
                   Text="{Binding PageName}" />

        <!-- Row 1 — Cinq en-têtes de colonnes -->
        <Border x:Name="SeriesOverdueHeaderBorder" Grid.Row="1" Grid.Column="0">
            <TextBlock x:Name="SeriesOverdueHeader" Text="{Binding Label_P10_02}" />
        </Border>
        <Border x:Name="SeriesToDoHeaderBorder" Grid.Row="1" Grid.Column="1">
            <TextBlock x:Name="SeriesToDoHeader" Text="{Binding Label_P10_01}" />
        </Border>
        <Border x:Name="SeriesInProgressHeaderBorder" Grid.Row="1" Grid.Column="2">
            <TextBlock x:Name="SeriesInProgressHeader" Text="{Binding Label_P10_03}" />
        </Border>
        <Border x:Name="SeriesCompletedHeaderBorder" Grid.Row="1" Grid.Column="3">
            <TextBlock x:Name="SeriesCompletedHeader" Text="{Binding Label_P10_04}" />
        </Border>
        <Border x:Name="SeriesUpcomingHeaderBorder" Grid.Row="1" Grid.Column="4">
            <TextBlock x:Name="SeriesUpcomingHeader" Text="{Binding Label_P10_05}" />
        </Border>

        <!-- Row 2 — Cinq listes de séries -->

        <!-- Colonne 1 — séries en retard -->
        <ScrollViewer x:Name="SeriesOverdueScrollViewer" Grid.Row="2" Grid.Column="0">
            <ListView x:Name="SeriesOverdueListView"
                      ItemsSource="{Binding SeriesOverdue}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal"
                                    Background="{Binding ProductionEndDay, Converter={StaticResource ProductionEndDayToBrush}}">
                            <StackPanel.InputBindings>
                                <MouseBinding Gesture="LeftClick"
                                              Command="{Binding DataContext.SelectSeriesCommand, RelativeSource={RelativeSource AncestorType={x:Type generic:Page_Generic}}}"
                                              CommandParameter="{Binding}" />
                            </StackPanel.InputBindings>
                            <TextBlock Text="{Binding IdSerialNumber}"
                                       Width="80" Padding="5,10,0,0" MinHeight="35"
                                       FontWeight="{Binding IsLate, Converter={StaticResource IsLateToFontWeight}}" />
                            <TextBlock Text="{Binding Description, Converter={StaticResource TruncateString}, ConverterParameter=25}"
                                       MinWidth="230" Padding="0,10,5,0" MinHeight="35"
                                       FontWeight="{Binding IsLate, Converter={StaticResource IsLateToFontWeight}}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>

        <!-- Colonne 2 — séries à réaliser -->
        <ScrollViewer x:Name="SeriesToDoScrollViewer" Grid.Row="2" Grid.Column="1">
            <ListView x:Name="SeriesToDoListView"
                      ItemsSource="{Binding SeriesToDo}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal"
                                    Background="{Binding ProductionEndDay, Converter={StaticResource ProductionEndDayToBrush}}">
                            <StackPanel.InputBindings>
                                <MouseBinding Gesture="LeftClick"
                                              Command="{Binding DataContext.SelectSeriesCommand, RelativeSource={RelativeSource AncestorType={x:Type generic:Page_Generic}}}"
                                              CommandParameter="{Binding}" />
                            </StackPanel.InputBindings>
                            <TextBlock Text="{Binding IdSerialNumber}"
                                       Width="80" Padding="5,10,0,0" MinHeight="35"
                                       FontWeight="{Binding IsLate, Converter={StaticResource IsLateToFontWeight}}" />
                            <TextBlock Text="{Binding Description, Converter={StaticResource TruncateString}, ConverterParameter=25}"
                                       MinWidth="230" Padding="0,10,5,0" MinHeight="35"
                                       FontWeight="{Binding IsLate, Converter={StaticResource IsLateToFontWeight}}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>

        <!-- Colonne 3 — séries en cours -->
        <ScrollViewer x:Name="SeriesInProgressScrollViewer" Grid.Row="2" Grid.Column="2">
            <ListView x:Name="SeriesInProgressListView"
                      ItemsSource="{Binding SeriesInProgress}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal"
                                    Background="{Binding ProductionEndDay, Converter={StaticResource ProductionEndDayToBrush}}">
                            <StackPanel.InputBindings>
                                <MouseBinding Gesture="LeftClick"
                                              Command="{Binding DataContext.SelectSeriesCommand, RelativeSource={RelativeSource AncestorType={x:Type generic:Page_Generic}}}"
                                              CommandParameter="{Binding}" />
                            </StackPanel.InputBindings>
                            <TextBlock Text="{Binding IdSerialNumber}"
                                       Width="80" Padding="5,10,0,0" MinHeight="35"
                                       FontWeight="{Binding IsLate, Converter={StaticResource IsLateToFontWeight}}" />
                            <TextBlock Text="{Binding Description, Converter={StaticResource TruncateString}, ConverterParameter=25}"
                                       MinWidth="230" Padding="0,10,5,0" MinHeight="35"
                                       FontWeight="{Binding IsLate, Converter={StaticResource IsLateToFontWeight}}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>

        <!-- Colonne 4 — séries réalisées -->
        <ScrollViewer x:Name="SeriesCompletedScrollViewer" Grid.Row="2" Grid.Column="3">
            <ListView x:Name="SeriesCompletedListView"
                      ItemsSource="{Binding SeriesCompleted}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal"
                                    Background="{Binding ProductionEndDay, Converter={StaticResource ProductionEndDayToBrush}}">
                            <StackPanel.InputBindings>
                                <MouseBinding Gesture="LeftClick"
                                              Command="{Binding DataContext.SelectSeriesCommand, RelativeSource={RelativeSource AncestorType={x:Type generic:Page_Generic}}}"
                                              CommandParameter="{Binding}" />
                            </StackPanel.InputBindings>
                            <TextBlock Text="{Binding IdSerialNumber}"
                                       Width="80" Padding="5,10,0,0" MinHeight="35"
                                       FontWeight="{Binding IsLate, Converter={StaticResource IsLateToFontWeight}}" />
                            <TextBlock Text="{Binding Description, Converter={StaticResource TruncateString}, ConverterParameter=25}"
                                       MinWidth="230" Padding="0,10,5,0" MinHeight="35"
                                       FontWeight="{Binding IsLate, Converter={StaticResource IsLateToFontWeight}}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>

        <!-- Colonne 5 — séries à venir -->
        <ScrollViewer x:Name="SeriesUpcomingScrollViewer" Grid.Row="2" Grid.Column="4">
            <ListView x:Name="SeriesUpcomingListView"
                      ItemsSource="{Binding SeriesUpcoming}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal"
                                    Background="{Binding ProductionEndDay, Converter={StaticResource ProductionEndDayToBrush}}">
                            <StackPanel.InputBindings>
                                <MouseBinding Gesture="LeftClick"
                                              Command="{Binding DataContext.SelectSeriesCommand, RelativeSource={RelativeSource AncestorType={x:Type generic:Page_Generic}}}"
                                              CommandParameter="{Binding}" />
                            </StackPanel.InputBindings>
                            <TextBlock Text="{Binding IdSerialNumber}"
                                       Width="80" Padding="5,10,0,0" MinHeight="35"
                                       FontWeight="{Binding IsLate, Converter={StaticResource IsLateToFontWeight}}" />
                            <TextBlock Text="{Binding Description, Converter={StaticResource TruncateString}, ConverterParameter=25}"
                                       MinWidth="230" Padding="0,10,5,0" MinHeight="35"
                                       FontWeight="{Binding IsLate, Converter={StaticResource IsLateToFontWeight}}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>

    </Grid>

</generic:Page_Generic>
