<UserControl x:Class="Shared.Views.Backgrounds.CommonBackground"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="MainBackgroundGrid" Background="White" >
        <Border x:Name="Background_1"/>
        <Border x:Name="Background_2"/>
        <Border x:Name="TitleBorder">
            <Grid x:Name="TitleGrid">
                <Image x:Name="LogoImage"/>
                <TextBlock  x:Name="TitleContent"/>
            </Grid>
        </Border>
    </Grid>
    
</UserControl>
